# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Cloudflare DNS API ────────────────────────────────────────────────────────
# Buat API token di: https://dash.cloudflare.com/profile/api-tokens
# Permission: Zone → DNS → Edit
CF_API_TOKEN=your-cloudflare-api-token
# Zone ID domain tepi.my.id — ada di halaman utama domain di Cloudflare dashboard
CF_ZONE_ID=your-zone-id
# Account ID — ada di sidebar kanan Cloudflare dashboard
CF_ACCOUNT_ID=your-account-id

# ─── Resend (email transaksional) ─────────────────────────────────────────────
# Daftar di: https://resend.com → API Keys
RESEND_API_KEY=re_your-api-key

# ─── Paywuz.id (pembayaran QRIS) ──────────────────────────────────────────────
# Daftar & buat project di: https://paywuz.id
# Pakai pk_sand_... dulu untuk testing (sandbox), ganti ke pk_live_... saat production
# Catatan: TIDAK ADA webhook secret terpisah — signature webhook diverifikasi
# memakai API key ini juga sebagai HMAC secret (lihat lib/paywuz.ts)
PAYWUZ_API_KEY=pk_sand_your_api_key

# ─── Admin ────────────────────────────────────────────────────────────────────
# Supabase user ID kamu (UUID) — lihat di Supabase → Authentication → Users
ADMIN_USER_ID=your-supabase-user-uuid

# ─── App ──────────────────────────────────────────────────────────────────────
# Formatnya: <nama-worker>.<subdomain-akun-kamu>.workers.dev
# Cek URL asli di Cloudflare dashboard setelah deploy pertama, lalu update nilai ini
NEXT_PUBLIC_APP_URL=https://tepi.workers.dev
NEXT_PUBLIC_ROOT_DOMAIN=tepi.my.id
